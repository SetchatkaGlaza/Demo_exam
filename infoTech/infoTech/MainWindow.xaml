<Window x:Class="infoTech.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учёт заявок на ремонт" Height="500" Width="1000" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель кнопок -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
            <Button x:Name="btnAdd" Content="Добавить" Width="80" Height="25" Margin="5" Click="btnAdd_Click"/>
            <Button x:Name="btnEdit" Content="Редактировать" Width="100" Height="25" Margin="5" Click="btnEdit_Click"/>
            <Button x:Name="btnDelete" Content="Удалить" Width="80" Height="25" Margin="5" Click="btnDelete_Click"/>
            <Button x:Name="btnSearch" Content="Поиск по номеру" Width="120" Height="25" Margin="5" Click="btnSearch_Click"/>
            <Button x:Name="btnStats" Content="Статистика" Width="100" Height="25" Margin="5" Click="btnStats_Click"/>
            <Button x:Name="btnComments" Content="Комментарии" Width="100" Height="25" Margin="5" Click="btnComments_Click"/>
        </StackPanel>

        <!-- DataGrid с заявками -->
        <DataGrid x:Name="dgRequests" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" Margin="5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№ заявки" Binding="{Binding requestID}" Width="70"/>
                <DataGridTextColumn Header="Дата добавления" Binding="{Binding startDate, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding DeviceTypes.typeName}" Width="100"/>
                <DataGridTextColumn Header="Модель" Binding="{Binding deviceModel}" Width="150"/>
                <DataGridTextColumn Header="Проблема" Binding="{Binding problemDescription}" Width="200"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding RequestStatuses.statusName}" Width="120"/>
                <DataGridTextColumn Header="Заказчик" Binding="{Binding Clients.fio}" Width="150"/>
                <DataGridTextColumn Header="Мастер" Binding="{Binding Masters.fio}" Width="150"/>
                <DataGridTextColumn Header="Дата завершения" Binding="{Binding completionDate, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Строка состояния -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" Text="Готово"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>