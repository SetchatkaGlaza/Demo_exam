<Window x:Class="infoTech.CommentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Комментарии к заявке" Height="400" Width="500" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label x:Name="lblRequestInfo" Grid.Row="0" Content="" FontWeight="Bold" Margin="5"/>

        <ListBox x:Name="lbComments" Grid.Row="1" DisplayMemberPath="message" Margin="5"/>

        <TextBox x:Name="txtNewComment" Grid.Row="2" Margin="5" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

        <Button x:Name="btnAddComment" Grid.Row="3" Content="Добавить комментарий" Width="150" Height="25" Margin="5" Click="btnAddComment_Click"/>
    </Grid>
</Window>