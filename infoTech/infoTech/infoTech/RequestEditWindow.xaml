<Window x:Class="infoTech.RequestEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование заявки" Height="500" Width="500" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Дата добавления -->
        <Label Grid.Row="0" Grid.Column="0" Content="Дата добавления:" Margin="5"/>
        <DatePicker x:Name="dpStartDate" Grid.Row="0" Grid.Column="1" Margin="5" SelectedDate="{Binding startDate}"/>

        <!-- Тип устройства -->
        <Label Grid.Row="1" Grid.Column="0" Content="Тип устройства:" Margin="5"/>
        <ComboBox x:Name="cmbDeviceType" Grid.Row="1" Grid.Column="1" Margin="5" DisplayMemberPath="typeName" SelectedValuePath="typeID"/>

        <!-- Модель -->
        <Label Grid.Row="2" Grid.Column="0" Content="Модель:" Margin="5"/>
        <TextBox x:Name="txtModel" Grid.Row="2" Grid.Column="1" Margin="5"/>

        <!-- Описание проблемы -->
        <Label Grid.Row="3" Grid.Column="0" Content="Проблема:" Margin="5"/>
        <TextBox x:Name="txtProblem" Grid.Row="3" Grid.Column="1" Margin="5" TextWrapping="Wrap" AcceptsReturn="True" Height="60"/>

        <!-- Статус -->
        <Label Grid.Row="4" Grid.Column="0" Content="Статус:" Margin="5"/>
        <ComboBox x:Name="cmbStatus" Grid.Row="4" Grid.Column="1" Margin="5" DisplayMemberPath="statusName" SelectedValuePath="statusID"/>

        <!-- Мастер -->
        <Label Grid.Row="5" Grid.Column="0" Content="Мастер:" Margin="5"/>
        <ComboBox x:Name="cmbMaster" Grid.Row="5" Grid.Column="1" Margin="5" DisplayMemberPath="fio" SelectedValuePath="masterID"/>

        <!-- Заказчик -->
        <Label Grid.Row="6" Grid.Column="0" Content="Заказчик:" Margin="5"/>
        <ComboBox x:Name="cmbClient" Grid.Row="6" Grid.Column="1" Margin="5" DisplayMemberPath="fio" SelectedValuePath="clientID"/>

        <!-- Дата завершения -->
        <Label Grid.Row="7" Grid.Column="0" Content="Дата завершения:" Margin="5"/>
        <DatePicker x:Name="dpCompletionDate" Grid.Row="7" Grid.Column="1" Margin="5"/>

        <!-- Запчасти -->
        <Label Grid.Row="8" Grid.Column="0" Content="Запчасти:" Margin="5"/>
        <TextBox x:Name="txtRepairParts" Grid.Row="8" Grid.Column="1" Margin="5" TextWrapping="Wrap" Height="40"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button x:Name="btnSave" Content="Сохранить" Width="100" Height="25" Margin="5" Click="btnSave_Click"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="100" Height="25" Margin="5" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>