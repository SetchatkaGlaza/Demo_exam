<Window x:Class="infoTech.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Статистика" Height="400" Width="600" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Content="Количество выполненных заявок по мастерам" FontWeight="Bold" Margin="5"/>
        <DataGrid x:Name="dgMasterStats" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True" Margin="5"/>

        <Label Grid.Row="2" Content="Количество заявок по типам устройств" FontWeight="Bold" Margin="5"/>
        <DataGrid x:Name="dgDeviceStats" Grid.Row="3" AutoGenerateColumns="True" IsReadOnly="True" Margin="5"/>
    </Grid>
</Window>